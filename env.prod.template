# ===========================================
# RÉFÉRENCE UNIQUEMENT – Pas chargé automatiquement
# ===========================================
# Ce fichier sert de checklist. Les variables doivent être définies dans
# Portainer (Environment variables de la stack) ou dans un .env au moment de
# `docker compose up`. Les valeurs ci‑dessous sont des exemples à adapter.

# ===========================================
# AWS (uniquement si docker-compose.prod.yml sans .ghcr)
# ===========================================
AWS_ACCOUNT_ID=123456789012
AWS_REGION=eu-west-1

# ===========================================
# MongoDB
# ===========================================
MONGO_PASSWORD=VotreMotDePasseSecurise123!

# ===========================================
# Jira (requis)
# ===========================================
JIRA_URL=https://votre-instance.atlassian.net
JIRA_EMAIL=votre-email@example.com
JIRA_API_TOKEN=votre-api-token-jira
JIRA_PROJECT_KEY=PROJ
JIRA_BOARD_ID=1

# Jira optionnel (projets Support / REL, champs custom, résolus par jour)
# JIRA_SUPPORT_PROJECT_KEY=SB
# JIRA_REL_PROJECT_KEY=REL
# JIRA_PONDERATION_FIELD=customfield_10727
# JIRA_STORY_POINTS_FIELD=customfield_10127
# JIRA_TEAM_FIELD=customfield_10108
# JIRA_RESOLVED_STATUS=--Terminé--
# JIRA_RESOLUTION_NAME=Resolved
# JIRA_RESOLVED_BY_DAY_PROJECT=PROJ
# JIRA_RESOLVED_BY_DAY_TYPES=US,"Tâche Tech","Bug dev"

# ===========================================
# JWT (recommandé en production)
# ===========================================
JWT_SECRET=votre-secret-jwt-min-32-caracteres
JWT_EXPIRES_IN=24h

# ===========================================
# EMAIL / RÉINITIALISATION DE MOT DE PASSE (recommandé)
# Utilise Nodemailer (SMTP interne, sans dépendance externe)
# APP_BASE_URL : URL publique du frontend
# SMTP_HOST    : votre serveur SMTP
# SMTP_PORT    : 587 (STARTTLS) ou 465 (SSL)
# SMTP_SECURE  : true si port 465
# SMTP_USER    : login SMTP / adresse expéditeur
# SMTP_PASS    : mot de passe SMTP
# EMAIL_FROM_NAME : nom affiché dans le champ "De:"
# ===========================================
APP_BASE_URL=https://jira-kpi.imagiro.fr

# --- Scaleway Transactional Email (TEM) ---
# 1. Console Scaleway > Transactional Email > créer un projet
# 2. Ajouter le domaine imagiro.fr > configurer les enregistrements DNS (SPF, DKIM)
# 3. Générer des credentials SMTP (username = project-id, password = secret key)
# Doc : https://www.scaleway.com/en/docs/managed-services/transactional-email/
SMTP_HOST=smtp.tem.scw.cloud
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=votre-project-id-scaleway
SMTP_PASS=votre-secret-key-scaleway-tem
EMAIL_FROM_NAME=Jira KPI Dashboard

# ===========================================
# CORS – domaine du front (ex. https://jira-kpi.imagiro.fr)
# ===========================================
CORS_ORIGIN=https://votre-domaine.com

# ===========================================
# Microsoft SSO (optionnel – pour le bouton « Se connecter avec Microsoft »)
# ===========================================
# MICROSOFT_CLIENT_ID=xxx
# MICROSOFT_TENANT_ID=xxx
# MICROSOFT_REDIRECT_URI=https://votre-domaine.com/auth/microsoft/callback

# ===========================================
# AI (optionnel)
# ===========================================
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ===========================================
# Brevo / Monday (optionnel)
# ===========================================
# BREVO_API_KEY=
# MONDAY_API_KEY=

# ===========================================
# Frontend – build Vite uniquement
# ===========================================
# À passer au BUILD de l’image frontend (pas au runtime). Ex. CI/CD ou Docker build-arg.
# Si front et API même domaine : https://votre-domaine.com/api
VITE_API_URL=https://votre-domaine.com/api
