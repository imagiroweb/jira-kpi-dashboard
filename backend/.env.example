# ===========================================
# JIRA CONFIGURATION (REQUIRED)
# ===========================================
# URL de votre instance Jira (ex: https://yourcompany.atlassian.net)
JIRA_URL=https://your-company.atlassian.net

# Email du compte Jira
JIRA_EMAIL=your-email@company.com

# Token API Jira (créé depuis: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your-api-token-here

# Clés des projets Jira (séparées par des virgules)
JIRA_PROJECT_KEYS=TEAM1,TEAM2,TEAM3,QS

# Fuseau IANA pour comparer les dates de worklog au filtre (aligné sur worklogDate Jira). Défaut Europe/Paris.
# JIRA_WORKLOG_DATE_TZ=Europe/Paris

# Nombre d'appels Jira GET worklog en parallèle par lot (défaut 10, max 30). Monter si l'API le supporte sans 429.
# JIRA_WORKLOG_FETCH_CONCURRENCY=10

# ID du board Jira (optionnel, pour les sprints)
JIRA_BOARD_ID=

# Graphique "Tickets résolus par jour" (Dashboard) : filtre par projet et types
# Si défini, le graphique utilise le JQL (project + types + resolution + resolutiondate) puis agrégation :
#   team = par équipe (champ JIRA_TEAM_FIELD, mappé aux boards configurés) — défaut
#   type = par type de ticket (US, Tâche Tech, Bug dev)
# JIRA_RESOLVED_BY_DAY_PROJECT=ADORIA26
# JIRA_RESOLVED_BY_DAY_TYPES=US,"Tâche Tech","Bug dev"
# JIRA_RESOLVED_BY_DAY_GROUP_BY=team

# ===========================================
# CUSTOM FIELDS (adapter selon votre Jira)
# ===========================================
# Champ Story Points (trouvez-le dans Jira Admin > Issues > Custom Fields)
JIRA_STORY_POINTS_FIELD=customfield_10127

# Champ Pondération
JIRA_PONDERATION_FIELD=customfield_10727

# Champ Team
JIRA_TEAM_FIELD=customfield_10001

# Macro chiffrage (Suivi epics) : champ sur l'epic (en jours homme), converti en heures pour comparer au temps passé.
# ID = 10992 → customfield_10992. Conversion : 1 jour homme = JIRA_MACRO_CHIFFRAGE_HOURS_PER_DAY heures (défaut 7,5).
JIRA_MACRO_CHIFFRAGE_FIELD=customfield_10992
JIRA_MACRO_CHIFFRAGE_HOURS_PER_DAY=7.5

# Champ Équipe Worklog (optionnel) : utilisé pour filtrer les worklogs par équipe (API worklog).
# Si non défini, JIRA_TEAM_FIELD est utilisé.
# JIRA_WORKLOG_TEAM_FIELD=customfield_10108

# ===========================================
# WORKLOGPRO / EXPORT WORKLOG (optionnel)
# ===========================================
# Pour un rapport worklog exhaustif, une app d'export (ex. WorklogPro, tableau de bord)
# peut être branchée via WORKLOG_URL + clé si l’API est implémentée côté backend.
WORKLOGPRO_API_KEY=
WORKLOG_URL=

# ===========================================
# AI CONFIGURATION (optionnel)
# ===========================================
# Clé API Anthropic pour les insights AI
ANTHROPIC_API_KEY=

# Ou clé API OpenAI
OPENAI_API_KEY=

# ===========================================
# MICROSOFT SSO (optionnel)
# ===========================================
# Si ces variables sont définies, le bouton "Microsoft" apparaît sur la page de connexion.
# Créer une application dans Azure AD (Portail Azure > Inscriptions d’applications) et définir
# une redirection SPA : https://votre-domaine/auth/microsoft/callback (ou http://localhost:3001/auth/microsoft/callback en dev).
# MICROSOFT_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# MICROSOFT_TENANT_ID=common
# MICROSOFT_REDIRECT_URI=http://localhost:3001/auth/microsoft/callback

# ===========================================
# DATABASE
# ===========================================
# URI MongoDB (auth, sync, rôles). Si MongoDB utilise un user admin, ajouter ?authSource=admin
# Ex: MONGODB_URI=mongodb://admin:password@localhost:27017/jira-kpi?authSource=admin
MONGODB_URI=mongodb://localhost:27017/jira-kpi

# ===========================================
# SERVER
# ===========================================
PORT=3002
NODE_ENV=development
