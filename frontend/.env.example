# URL de l'API (build et dev). Utilisée par authApi, api, etc.
# Local : backend sur 3002
# En dev avec .env à la racine (envDir: '..'), l’URL doit inclure /api (routes backend).
VITE_API_URL=http://localhost:3002/api
# Production : même principe avec /api à la fin
# VITE_API_URL=https://jira-kpi.imagiro.fr/api

# Optionnel : ID du board Monday « Suivi clients par CP » pour afficher les KPI automatiquement (sinon recherche par nom du board).
# VITE_MONDAY_SUIVI_CLIENT_BOARD_ID=1234567890
